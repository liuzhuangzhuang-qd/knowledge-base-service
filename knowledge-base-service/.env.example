APP_NAME=knowledge-base-service
APP_ENV=dev
SECRET_KEY=replace_me_secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATABASE_URL=postgresql+psycopg2://kb_user:kb_pass@db:5432/kb_service
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_SIZE_MB=20

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBED_MODEL=text-embedding-v3

VECTOR_DIM=1024
RETRIEVAL_VECTOR_TOPK=12
RETRIEVAL_KEYWORD_TOPK=10
RERANK_KEEP_TOPK=5
